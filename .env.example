# Server
PORT=8080

# Database - Supabase Transaction Pooler (port 6543)
DATABASE_URL=jdbc:postgresql://<project-ref>.pooler.supabase.com:6543/postgres
DATABASE_USERNAME=postgres.<project-ref>
DATABASE_PASSWORD=your-supabase-db-password

# Spring Profile
SPRING_PROFILES_ACTIVE=prod

# CORS - comma-separated list of allowed origins (* allows all)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Tip: If connection fails, add ?sslmode=require to DATABASE_URL
